# Senha de acesso ao site (obrigatório em produção)
APP_PASSWORD=troque-por-uma-senha-forte

# Segredo para assinar sessões (recomendado; se omitido, usa APP_PASSWORD)
SESSION_SECRET=uma-string-aleatoria-longa

# Porta HTTP (padrão 3000)
PORT=3000

# Limites de upload (MB)
MAX_IMAGE_MB=25
MAX_VIDEO_MB=200

# Timeout FFmpeg para vídeos (ms)
FFMPEG_FAST_TIMEOUT_MS=300000
FFMPEG_MAX_TIMEOUT_MS=900000
